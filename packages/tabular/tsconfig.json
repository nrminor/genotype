{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "incremental": false,
    "composite": false,
    "strict": true,
    "target": "ES2022",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "rewriteRelativeImportExtensions": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noFallthroughCasesInSwitch": true,
    // "noUnusedLocals": true,
    // "noUnusedParameters": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "allowUnreachableCode": false,
    "allowUnusedLabels": false,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "../..",
    "removeComments": false,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "lib": ["ES2022", "DOM"],
    "types": ["bun", "node"],
    "paths": {
      "@genotype/core": ["../core/src/index.ts"],
      "@genotype/core/seqops": ["../core/src/operations/index.ts"],
      "@genotype/core/*": ["../core/src/*"],
      "@genotype/tabular": ["./src/index.ts"],
      "@genotype/tabular/*": ["./src/*"],
      "@genotype/wasm-pkg/*": ["../../crates/wasm-adapter/pkg/*"]
    },
    "plugins": [{ "name": "@effect/language-service" }]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "test", "docs"]
}
