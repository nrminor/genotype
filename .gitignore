# Ignore everything by default
*

# === PROJECT CONFIGURATION ===
# Package management and tooling config
!/.gitignore
!/package.json
!/bun.lock
!/tsconfig.json
!/.oxlintrc.json
!/.oxfmtrc.json
!/justfile

# === RUST WORKSPACE ===
# Workspace configuration
!/Cargo.toml
!/rust-analyzer.json
!/rust-toolchain
!/rust-toolchain.toml
!/.rustfmt.toml
!/rustfmt.toml
!/clippy.toml
!/.clippy.toml

# Cargo build configuration
!/.cargo/
!/.cargo/config.toml

# Cross-compilation config
!/Cross.toml

# Documentation
!/README.md
!/AGENTS.md
!/LICENSE

# === PACKAGES WORKSPACE ===
!/packages/
!/packages/core/
!/packages/core/package.json
!/packages/core/tsconfig.json
!/packages/core/tsconfig.test.json
!/packages/tabular/
!/packages/tabular/package.json
!/packages/tabular/tsconfig.json
!/packages/tabular/tsconfig.test.json
!/packages/parquet/
!/packages/parquet/package.json
!/packages/parquet/tsconfig.json
!/packages/parquet/tsconfig.test.json

# === SOURCE CODE ===
# Main TypeScript source
!/packages/core/src/
!/packages/core/src/*.ts
!/packages/core/src/formats/
!/packages/core/src/formats/*.ts
!/packages/core/src/formats/bam/
!/packages/core/src/formats/bam/*.ts
!/packages/core/src/formats/gtf/
!/packages/core/src/formats/gtf/*.ts
!/packages/core/src/formats/fastq/
!/packages/core/src/formats/fastq/*.ts
!/packages/core/src/formats/json/
!/packages/core/src/formats/json/*.ts
!/packages/core/src/io/
!/packages/core/src/io/*.ts
!/packages/core/src/utils/
!/packages/core/src/utils/*.ts
!/packages/core/src/validation/
!/packages/core/src/validation/*.ts
!/packages/core/src/operations/
!/packages/core/src/operations/*.ts
!/packages/core/src/operations/core/
!/packages/core/src/operations/core/*.ts
!/packages/core/src/operations/core/quality/
!/packages/core/src/operations/core/quality/*.ts
!/packages/core/src/compression/
!/packages/core/src/compression/*.ts
!/packages/core/src/backend/
!/packages/core/src/backend/*.ts

# Napi-rs build artifacts (generated by napi build, no source code here)
!/packages/core/src/native/
!/packages/core/src/native/index.js
!/packages/core/src/native/index.d.ts

# === RUST ENGINE & ADAPTER CRATES ===
!/crates/
!/crates/engine/
!/crates/engine/Cargo.toml
!/crates/engine/src/
!/crates/engine/src/*.rs
!/crates/napi-adapter/
!/crates/napi-adapter/Cargo.toml
!/crates/napi-adapter/build.rs
!/crates/napi-adapter/src/
!/crates/napi-adapter/src/*.rs
!/crates/wasm-adapter/
!/crates/wasm-adapter/Cargo.toml
!/crates/wasm-adapter/src/
!/crates/wasm-adapter/src/*.rs

# === EXAMPLES & DOCUMENTATION ===
# Usage examples
!/examples/
!/examples/*.ts

# === TESTS ===
# Test files organized by module
!/packages/core/test/
!/packages/core/test/formats/
!/packages/core/test/formats/*.test.ts
!/packages/core/test/compression/
!/packages/core/test/compression/*.test.ts
!/packages/core/test/io/
!/packages/core/test/io/*.test.ts
!/packages/core/test/operations/
!/packages/core/test/operations/*.test.ts
!/packages/core/test/operations/core/
!/packages/core/test/operations/core/*.test.ts
!/packages/core/test/operations/processors/
!/packages/core/test/operations/processors/*.test.ts
!/packages/core/test/integration/
!/packages/core/test/integration/*.test.ts
!/packages/core/test/native/
!/packages/core/test/native/*.test.ts
!/packages/core/test/native/*.ts
!/packages/core/test/utils/
!/packages/core/test/utils/*.test.ts
!/packages/core/test/utils/*.ts
!/packages/core/test/*.test.ts
!/packages/core/test/matchers.ts

# Test data fixtures
!/packages/core/test/fixtures/
!/packages/core/test/fixtures/*.fasta
!/packages/core/test/fixtures/*.fastq
!/packages/core/test/fixtures/*.bed
!/packages/core/test/fixtures/*.bam
!/packages/core/test/fixtures/*.sam
!/packages/core/test/fixtures/*.json
!/packages/core/test/fixtures/*.jsonl
!/packages/core/test/fixtures/*.tsv

# === TABULAR PACKAGE ===
# Source
!/packages/tabular/src/
!/packages/tabular/src/*.ts
!/packages/tabular/src/dsv/
!/packages/tabular/src/dsv/*.ts
# Tests
!/packages/tabular/test/
!/packages/tabular/test/*.test.ts

# === PARQUET PACKAGE ===
# Source
!/packages/parquet/src/
!/packages/parquet/src/*.ts
# Tests
!/packages/parquet/test/
!/packages/parquet/test/*.test.ts

# === BUILD & DEPLOYMENT SCRIPTS ===
# Automation scripts
!/packages/core/scripts/
!/packages/core/scripts/build.mjs
!/packages/core/scripts/pack.mjs
!/packages/core/scripts/publish.mjs

# === GITHUB WORKFLOWS ===
# CI/CD and automation
!/.github/
!/.github/workflows/
!/.github/workflows/*.yml
!/.github/workflows/*.yaml
