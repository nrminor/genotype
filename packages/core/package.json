{
  "name": "@genotype/core",
  "version": "0.1.0",
  "description": "A feature-rich TypeScript library for working with genomic data formats (FASTA, FASTQ, SAM, BAM, BED)",
  "keywords": [
    "bam",
    "bed",
    "bioinformatics",
    "fasta",
    "fastq",
    "genomics",
    "performance",
    "sam",
    "streaming",
    "typescript"
  ],
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/nrminor/genotype",
    "directory": "packages/core"
  },
  "files": [
    "dist",
    "LICENSE*",
    "README.md",
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "module": "src/index.ts",
  "browser": {
    "./src/backend/node-native.ts": false,
    "./dist/backend/node-native.js": false
  },
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bun run build:native && bun run build:wasm && bun run build:lib",
    "build:lib": "bun scripts/build.mjs --lib",
    "build:native": "bun scripts/build.mjs --native",
    "build:native:dev": "bun scripts/build.mjs --native --dev",
    "build:wasm": "bun scripts/build.mjs --wasm",
    "build:wasm:dev": "bun scripts/build.mjs --wasm --dev",
    "clean": "rm -rf dist",
    "docs": "typedoc",
    "lint": "bunx oxlint",
    "lint:fix": "bunx oxlint --fix",
    "lint:types": "bunx oxlint --type-aware",
    "prepublishOnly": "bun run clean && bun run build",
    "test": "bun test test/",
    "typecheck": "bunx tsgo --noEmit -p tsconfig.test.json"
  },
  "dependencies": {
    "@effect/platform-bun": "4.0.0-beta.34",
    "@effect/platform-node": "4.0.0-beta.34",
    "@hpcc-js/wasm-zstd": "^1.12.1",
    "arktype": "^2.2.0",
    "effect": "4.0.0-beta.34",
    "fflate": "^0.8.2"
  },
  "devDependencies": {
    "@effect/language-service": "^0.80.0",
    "@napi-rs/cli": "^3.5.1",
    "@types/bun": "^1.3.10",
    "@types/node": "^22.19.15",
    "tsd": "^0.33.0"
  },
  "peerDependencies": {
    "typescript": ">5.9.3"
  },
  "engines": {
    "bun": ">=1.2.0"
  }
}
