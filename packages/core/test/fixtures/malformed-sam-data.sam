@YY	Invalid header type

# Malformed header fields
@HD	INVALID_FIELD
@HD	VN	Missing colon separator
@SQ	SN:chr1	Invalid length field
@SQ	SN:chr2	LN:NOT_A_NUMBER

# Missing required header fields
@HD	SO:coordinate
@SQ	SN:chr1
@RG	SM:sample1
@PG	VN:1.0

